<policies>
    <inbound>
        <base />
        <rate-limit-by-key calls="600" renewal-period="60" counter-key="@((string)(context.Request.IpAddress ?? &quot;anonymous&quot;))" />
        <!-- All requests get the trusted header so backend can detect APIM transit
             (used to short-circuit the / -> APIM redirect loop and to consume the
             delegated auth boundary on /api/*). The secret value is identical for
             both branches; only /api/* is JWT-validated below. SPA static handlers
             do not consume the header, so wider injection is functionally safe. -->
        <set-header name="X-Apim-Trusted" exists-action="override">
            <value>{{trusted-auth-header-secret}}</value>
        </set-header>
        <!-- /api/* に Authorization ヘッダがある場合のみ JWT 検証する。
             - 匿名 demo: Authorization なし → 検証スキップ → backend が anonymous identity で処理
             - 認証済み: Authorization あり → validate-jwt が enforce → appid/azp 一致のみ通す
             APIM の context.Request.Url.Path は API base path (/app) を strip した
             相対パス (/api/health 等) を返すため、ここでは /api 直接 match で OK。 -->
        <set-variable name="reqPath" value="@(context.Request.Url.Path.ToLower())" />
        <set-variable name="hasAuthHeader" value="@(!string.IsNullOrEmpty(context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, string.Empty)))" />
        <choose>
            <when condition="@((((string)context.Variables[&quot;reqPath&quot;]).Equals(&quot;/api&quot;) || ((string)context.Variables[&quot;reqPath&quot;]).StartsWith(&quot;/api/&quot;)) &amp;&amp; (bool)context.Variables[&quot;hasAuthHeader&quot;])">
                <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized: invalid or missing token." require-expiration-time="true" require-scheme="Bearer" require-signed-tokens="true" output-token-variable-name="jwt">
                    <openid-config url="https://login.microsoftonline.com/{{tenant-id}}/v2.0/.well-known/openid-configuration" />
                    <audiences>
                        <audience>{{expected-jwt-audience}}</audience>
                    </audiences>
                    <issuers>
                        <issuer>https://login.microsoftonline.com/{{tenant-id}}/v2.0</issuer>
                        <issuer>https://sts.windows.net/{{tenant-id}}/</issuer>
                    </issuers>
                    <required-claims>
                        <claim name="tid" match="any">
                            <value>{{tenant-id}}</value>
                        </claim>
                    </required-claims>
                </validate-jwt>
                <choose>
                    <when condition="@(((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;appid&quot;, string.Empty) != &quot;{{frontend-client-id}}&quot; &amp;&amp; ((Jwt)context.Variables[&quot;jwt&quot;]).Claims.GetValueOrDefault(&quot;azp&quot;, string.Empty) != &quot;{{frontend-client-id}}&quot;)">
                        <return-response>
                            <set-status code="403" reason="Forbidden" />
                            <set-body>{"error":"Forbidden: client application not allowed"}</set-body>
                        </return-response>
                    </when>
                </choose>
            </when>
            <!-- SPA 静的アセット (/, /assets/*, /auth-redirect.html) と匿名 /api/* も
                 X-Apim-Trusted を持つが、backend は Authorization なしを anonymous として
                 扱うため (REQUIRE_AUTHENTICATED_OWNER=false)、secret 流出にはならない。 -->
        </choose>
    </inbound>
    <backend>
        <forward-request timeout="600" buffer-response="false" />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
