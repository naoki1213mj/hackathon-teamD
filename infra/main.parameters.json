{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "imageName": {
      "value": "${SERVICE_WEB_IMAGE_NAME=}"
    },
    "enableContainerAppsVnetIntegration": {
      "value": "${ENABLE_CONTAINER_APPS_VNET_INTEGRATION=false}"
    },
    "containerAppsVnetIntegrationMigrationApproval": {
      "value": "${CONTAINER_APPS_VNET_INTEGRATION_MIGRATION_APPROVAL=}"
    },
    "containerAppMaxReplicas": {
      "value": "${CONTAINER_APP_MAX_REPLICAS=1}"
    },
    "managerApprovalTriggerUrl": {
      "value": "${MANAGER_APPROVAL_TRIGGER_URL=}"
    },
    "postApprovalTeamsConnectionName": {
      "value": "${POST_APPROVAL_TEAMS_CONNECTION_NAME=}"
    },
    "postApprovalTeamsTeamId": {
      "value": "${POST_APPROVAL_TEAMS_TEAM_ID=}"
    },
    "postApprovalTeamsChannelId": {
      "value": "${POST_APPROVAL_TEAMS_CHANNEL_ID=}"
    },
    "postApprovalSharePointSiteId": {
      "value": "${POST_APPROVAL_SHAREPOINT_SITE_ID=}"
    },
    "imageProjectEndpointMai": {
      "value": "${IMAGE_PROJECT_ENDPOINT_MAI=}"
    },
    "maiResourceName": {
      "value": "${MAI_RESOURCE_NAME=}"
    },
    "voiceSpaClientId": {
      "value": "${VOICE_SPA_CLIENT_ID=}"
    },
    "searchEndpoint": {
      "value": "${SEARCH_ENDPOINT=}"
    },
    "searchApiKey": {
      "value": "${SEARCH_API_KEY=}"
    },
    "fabricSqlEndpoint": {
      "value": "${FABRIC_SQL_ENDPOINT=}"
    },
    "fabricLakehouseDatabase": {
      "value": "${FABRIC_LAKEHOUSE_DATABASE=}"
    },
    "fabricSalesTable": {
      "value": "${FABRIC_SALES_TABLE=}"
    },
    "fabricReviewsTable": {
      "value": "${FABRIC_REVIEWS_TABLE=}"
    },
    "fabricDataAgentUrl": {
      "value": "${FABRIC_DATA_AGENT_URL=}"
    },
    "fabricDataAgentUrlV2": {
      "value": "${FABRIC_DATA_AGENT_URL_V2=}"
    },
    "fabricDataAgentRuntime": {
      "value": "${FABRIC_DATA_AGENT_RUNTIME=}"
    },
    "fabricDataAgentRuntimeVersion": {
      "value": "${FABRIC_DATA_AGENT_RUNTIME_VERSION=}"
    },
    "workIqTimeoutSeconds": {
      "value": "${WORK_IQ_TIMEOUT_SECONDS=}"
    },
    "trustedAuthHeaderName": {
      "value": "${TRUSTED_AUTH_HEADER_NAME=}"
    },
    "trustedAuthHeaderSecret": {
      "value": "${TRUSTED_AUTH_HEADER_SECRET=}"
    },
    "trustAuthHeaderClaims": {
      "value": "${TRUST_AUTH_HEADER_CLAIMS=}"
    },
    "publicAppBaseUrl": {
      "value": "${PUBLIC_APP_BASE_URL=}"
    },
    "frontendClientId": {
      "value": "${FRONTEND_CLIENT_ID=}"
    },
    "expectedJwtAudience": {
      "value": "${EXPECTED_JWT_AUDIENCE=https://ai.azure.com}"
    }
  }
}
